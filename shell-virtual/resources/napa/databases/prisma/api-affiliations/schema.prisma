/// Prisma Client - genera el cliente tipado para acceder a la base de datos.
generator client {
  provider = "prisma-client-js"
}

/// Datasource principal conectado a PostgreSQL mediante la variable de entorno `DATABASE_URL`.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Tipos posibles de entidades dentro del grafo de afiliaciones.
enum PartyType {
  AFFILIATE
  PLAYER
  ORGANIZATION
}

/// Estados semánticos reutilizables para indicar la vigencia de un registro.
enum RecordStatus {
  ACTIVE
  INACTIVE
  PENDING
  SUSPENDED
  ARCHIVED
}

/// Tipos de principal para asignación genérica de roles.
enum PrincipalType {
  PARTY
  USER
  SERVICE
}

/// Ámbitos de aplicación para roles y políticas.
enum AccessScopeType {
  GLOBAL
  ORGANIZATION
  PARTY
}

/// Efecto de una política o permiso.
enum PolicyEffect {
  ALLOW
  DENY
}

/// Catálogo de monedas soportadas por el sistema.
model Currency {
  id               String   @id /// Identificador ISO o personalizado (ej: "USD", "ARS").
  name             String
  symbol           String
  decimalPrecision Float    @default(0.01)
  type             String   @default("fiat") /// fiat, crypto, fantasy, etc.
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  parties Party[]
}

/// Entidad base para afiliados, jugadores y organizaciones.
model Party {
  id                 String       @id @default(uuid())
  shortId            String       @unique @default(cuid()) /// Identificador legible (ej: "AFF-7Q2vFZpT3mA")
  name               String
  alias              String?      @unique
  aliases            String[]     @default([])
  type               PartyType
  orgId              String?
  metadata           Json? /// Información de contacto (nombre, apellido, teléfono, dirección, email, username, identificadores, etc.).
  utm                Json? /// Datos de marketing digital o campaña (utm_source, utm_medium, utm_campaign, utm_term, utm_content)
  qrIdentifier       String?      @unique /// Identificador único del QR o elemento físico asociado al afiliador o jugador
  status             RecordStatus @default(ACTIVE)
  externalIdentifier String?      @unique /// Identificador externo (wallet, CRM, partner, etc.).
  balance            Decimal      @default(0) @db.Decimal(18, 2)
  currencyId         String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  currency              Currency?                 @relation(fields: [currencyId], references: [id], onDelete: SetNull)
  ancestors             PartyClosure[]            @relation("ancestor")
  descendants           PartyClosure[]            @relation("descendant")
  referralTerms         PartyReferralTerm[]
  commissionTerms       PartyCommissionTerm[]
  principalRoleScopes   PrincipalRoleAssignment[] @relation("PrincipalPartyRoles")
  scopedRoleAssignments PrincipalRoleAssignment[] @relation("ScopePartyRoles")
  scopedPolicyRules     AccessPolicyRule[]        @relation("ScopePartyPolicies")

  @@index([alias])
  @@index([status])
  @@index([externalIdentifier])
  @@index([qrIdentifier])
  @@index([currencyId])
  @@index([orgId])
}

/// Tabla de clausura para representar rutas jerárquicas (path enumeration).
model PartyClosure {
  ancestorId   String
  descendantId String
  depth        Int
  createdAt    DateTime @default(now())

  ancestor   Party @relation("ancestor", fields: [ancestorId], references: [id], onDelete: Cascade)
  descendant Party @relation("descendant", fields: [descendantId], references: [id], onDelete: Cascade)

  @@id([ancestorId, descendantId])
  @@index([descendantId, depth])
  @@index([ancestorId, depth])
}

/// Historial de códigos de referido por afiliador.
model PartyReferralTerm {
  id             String       @id @default(uuid())
  shortId        String       @unique @default(cuid())
  partyId        String
  referralCode   String
  validityDays   Int?
  validityMonths Int?
  validFrom      DateTime     @default(now())
  validTo        DateTime?
  status         RecordStatus @default(ACTIVE)
  parentTermId   String?
  metadata       Json?
  createdBy      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  party      Party               @relation(fields: [partyId], references: [id], onDelete: Cascade)
  parentTerm PartyReferralTerm?  @relation("ReferralTermHierarchy", fields: [parentTermId], references: [id], onDelete: SetNull)
  childTerms PartyReferralTerm[] @relation("ReferralTermHierarchy")

  @@index([partyId, status])
  @@index([referralCode])
  @@index([validFrom, validTo])
  @@index([parentTermId])
}

/// Historial de porcentaje de comisión por afiliador.
model PartyCommissionTerm {
  id             String       @id @default(uuid())
  shortId        String       @unique @default(cuid())
  partyId        String
  percentage     Decimal      @db.Decimal(7, 4)
  validityDays   Int?
  validityMonths Int?
  validFrom      DateTime     @default(now())
  validTo        DateTime?
  status         RecordStatus @default(ACTIVE)
  parentTermId   String?
  metadata       Json?
  createdBy      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  party      Party                 @relation(fields: [partyId], references: [id], onDelete: Cascade)
  parentTerm PartyCommissionTerm?  @relation("CommissionTermHierarchy", fields: [parentTermId], references: [id], onDelete: SetNull)
  childTerms PartyCommissionTerm[] @relation("CommissionTermHierarchy")

  @@index([partyId, status])
  @@index([percentage])
  @@index([validFrom, validTo])
  @@index([parentTermId])
}

/// Catálogo de roles reutilizables.
model Role {
  id          String       @id @default(uuid())
  key         String       @unique /// Clave técnica estable (ej: AFFILIATE_ADMIN).
  name        String
  description String?
  status      RecordStatus @default(ACTIVE)
  isSystem    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  permissions RolePermission[]
  assignments PrincipalRoleAssignment[]

  @@index([status])
}

/// Catálogo de capacidades/acciones autorizables.
model Permission {
  id          String   @id @default(uuid())
  key         String   @unique /// Clave técnica estable (ej: party.createAffiliate).
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roles       RolePermission[]
  policyRules AccessPolicyRule[]
}

/// Matriz de permisos asignados a roles.
model RolePermission {
  roleId       String
  permissionId String
  effect       PolicyEffect @default(ALLOW)
  createdAt    DateTime     @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

/// Asignaciones de roles para principals (party/user/service) con scope y vigencia.
model PrincipalRoleAssignment {
  id                   String          @id @default(uuid())
  principalType        PrincipalType
  principalRef         String /// Identificador del principal (UUID, externalId, etc.).
  principalPartyId     String?
  roleId               String
  scopeType            AccessScopeType @default(GLOBAL)
  scopePartyId         String?
  inheritToDescendants Boolean         @default(true)
  validFrom            DateTime        @default(now())
  validTo              DateTime?
  status               RecordStatus    @default(ACTIVE)
  createdBy            String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  principalParty Party? @relation("PrincipalPartyRoles", fields: [principalPartyId], references: [id], onDelete: SetNull)
  role           Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  scopeParty     Party? @relation("ScopePartyRoles", fields: [scopePartyId], references: [id], onDelete: SetNull)

  @@index([principalType, principalRef, status])
  @@index([principalPartyId])
  @@index([scopeType, scopePartyId, status])
  @@index([roleId, status])
}

/// Reglas de política sobre permisos con efecto ALLOW/DENY y herencia por jerarquía.
model AccessPolicyRule {
  id                   String          @id @default(uuid())
  scopeType            AccessScopeType @default(GLOBAL)
  scopePartyId         String?
  permissionId         String
  effect               PolicyEffect
  inheritToDescendants Boolean         @default(true)
  priority             Int             @default(0)
  conditions           Json?
  validFrom            DateTime        @default(now())
  validTo              DateTime?
  status               RecordStatus    @default(ACTIVE)
  createdBy            String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  scopeParty Party?     @relation("ScopePartyPolicies", fields: [scopePartyId], references: [id], onDelete: SetNull)

  @@index([scopeType, scopePartyId, status])
  @@index([permissionId, status, effect])
}
